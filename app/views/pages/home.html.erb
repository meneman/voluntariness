<%= turbo_frame_tag "home" do %>

    <%= turbo_frame_tag "participants_list_home" do %>
      <%= render partial: "participants/list", locals: {participants: @participants} %>
    <% end %>


  <div class="flex flex-wrap gap-2  max-sm:justify-center" >
    <%= link_to "add task",  new_task_path, { data: { turbo_frame: "new_task" }, class: "m-4 bg-transparent hover:bg-blue-500 text-blue-700 font-semibold hover:text-white py-2 px-4 border border-blue-500 hover:border-transparent rounded"}%>
    <%= turbo_frame_tag "new_task"  %>
    <%= turbo_frame_tag "tasks_list_home", class:"contents" do  %>  
      <% @tasks.each do |task| %>
      <%= render partial: "tasks/task", locals: {participants: @participants, task: task}%>
      <%end%>
    <%end%>
  </div>
</div>
<%end%>
<%= turbo_stream_from "participants_points" %>