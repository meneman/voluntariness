
<%=  turbo_frame_tag "new_task" do %>
   <div style="max-width: 300px" class="relative m-8 bg-white  rounded-lg px-6 py-8 ring-1 ring-slate-900/5 shadow-xl">
    <%= render partial: "form", locals: {task: @task} %>
    <%= link_to "cancel", cancel_task_path, {data: { turbo_stream: true}, class: "text-red-600 absolute top-0 right-0 m-2 font-bold font-medium"} %>
    </div>
<% end %>
  